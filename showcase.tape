# VHS Tape: Agentic AI System (Recruiter Showcase)

Output media/elite_showcase.mp4

Set FontSize 18
Set Width 1300
Set Height 850
Set Padding 40
Set Theme "Catppuccin Macchiato"
Set TypingSpeed 50ms
Set CursorBlink true

# --- SCENE 1: HOOK ---
Type "# Building Production-Ready Agentic AI System..."
Enter
Sleep 1.5s
Type "# Problem: LLM systems lack reliability & evaluation"
Sleep 2s
Type "clear"
Enter

# --- SCENE 2: SYSTEM OVERVIEW ---
Type "# Architecture Overview"
Enter
Sleep 800ms
Type "tree -L 2"
Enter
Sleep 2s
Type "# Modular + Scalable Design"
Sleep 1.5s
Type "clear"
Enter

# --- SCENE 3: DOCUMENTATION ---
Type "# Documentation (Engineering Grade)"
Enter
Sleep 800ms
Type "glow README.md"
Enter
Sleep 2s
Down 20
Sleep 1.5s
Type "clear"
Enter

# --- SCENE 4: CORE ENGINE ---
Type "# Orchestration Engine"
Enter
Sleep 800ms
Type "cat orchestration/graph/core.py | head -n 30"
Enter
Sleep 3s
Type "# Deterministic Agent Workflow"
Sleep 1.5s
Type "clear"
Enter

# --- SCENE 5: EVALUATION ---
Type "# Evaluation Pipeline"
Enter
Sleep 800ms
Type "ls experiments/"
Enter
Sleep 1.5s
Type "# Metrics: Cost | Latency | Accuracy"
Sleep 2s
Type "# Result: 73% Cost Reduction"
Sleep 2s
Type "clear"
Enter

# --- SCENE 6: PRODUCTION CHECK ---
Type "# Running Production Checks..."
Enter
Sleep 500ms
Type "make lint"
Enter
Sleep 3s
Type "# Status: All checks passed"
Sleep 1.5s
Type "clear"
Enter

# --- SCENE 7: FINAL IMPACT ---
Type "# PRODUCTION READY SYSTEM"
Sleep 700ms
Type "# Latency: 1.8s (p95)"
Sleep 700ms
Type "# Accuracy: 94%"
Sleep 700ms
Type "# Scalable | Reliable | Deployable"
Sleep 2s

# --- SCENE 8: CTA ---
Type "# Explore Project:"
Sleep 500ms
Type "# github.com/ammmanism/agentic-ai-production-system"
Sleep 4s